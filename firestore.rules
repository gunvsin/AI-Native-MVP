rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all access by default for security.
    match /{document=**} {
      allow read, write: if false;
    }
    // Allow a logged-in user to read/write ONLY their own data.
    match /users/{userId}/{documents=**} {
       allow read, write: if request.auth.uid == userId;
    }
    // Allow a logged-in user to read/write their own financial data.
    match /financials/{userId}/{documents=**} {
       allow read, write: if request.auth.uid == userId;
    }
  }
}